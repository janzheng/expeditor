{
  "name": "@expeditor/expo",
  "version": "0.2.7",
  "exports": "./src/cli.ts",
  "imports": {
    "@mxit/parser": "../fold/src/mod.ts",
    "@snapshot/core": "../snapshot/src/mod.ts"
  },
  "tasks": {
    "expo": "deno run --allow-all src/cli.ts",
    "tui": "deno run --allow-all src/tui.tsx",
    "watch": "deno run --allow-read src/watch.ts",
    "tmux": "deno run --allow-all src/tmux-consumer.ts",
    "test": "bash tests/phase1-2/run-all.sh",
    "test:phase0": "bash tests/phase0/run-all.sh",
    "test:all": "bash tests/phase0/run-all.sh && bash tests/phase1-2/run-all.sh",
    "install": "deno compile --allow-all --output ~/.deno/bin/expo src/cli.ts && echo 'Installed: expo → ~/.deno/bin/expo'",
    "uninstall": "rm -f ~/.deno/bin/expo && echo 'Removed: ~/.deno/bin/expo'"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "npm:react@19"
  }
}
